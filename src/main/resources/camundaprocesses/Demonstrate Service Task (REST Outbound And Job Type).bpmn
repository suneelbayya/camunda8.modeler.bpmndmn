  <bpmn:process id="Process_0fre91a" name="Demonstrate Service Task (Rest Outbound And Job Type)" isExecutable="true">
    <bpmn:documentation>Start</bpmn:documentation>
    <bpmn:extensionElements />
    <bpmn:startEvent id="StartEvent_1" name="Process Start">
      <bpmn:documentation>Start</bpmn:documentation>
      <bpmn:outgoing>Flow_14y786t</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="Event_0htiae7" name="Process End">
      <bpmn:documentation>End</bpmn:documentation>
      <bpmn:incoming>Flow_1xlmfk7</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_14y786t" sourceRef="StartEvent_1" targetRef="Activity_1la42y6" />
    <bpmn:serviceTask id="Activity_1o9j5kz" name="Update State For Given Zip Code">
      <bpmn:documentation>Update State For Given Zip Code</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="UpdateStateForGivenZipCode" />
        <zeebe:ioMapping>
          <zeebe:input source="=zipCode" target="zipCode" />
          <zeebe:input source="=state" target="state" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1589cx1</bpmn:incoming>
      <bpmn:outgoing>Flow_1xlmfk7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1xlmfk7" sourceRef="Activity_1o9j5kz" targetRef="Event_0htiae7" />
    <bpmn:serviceTask id="Activity_1la42y6" name="Get StateBy Zip Code" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:documentation>Get Country By Zip Code</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="=&#34;https://api.zippopotam.us/us/&#34; + zipCode" target="url" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=false" target="followRedirects" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="12" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultVariable" value="countryData" />
          <zeebe:header key="resultExpression" value="={state : body.places[1].state}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_14y786t</bpmn:incoming>
      <bpmn:outgoing>Flow_1589cx1</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1589cx1" sourceRef="Activity_1la42y6" targetRef="Activity_1o9j5kz" />
  </bpmn:process>
